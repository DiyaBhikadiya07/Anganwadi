    <string-array name="childTips">
        <item>अपने बच्चे का आत्म-सम्मान बढ़ाना</item>
        <item>बच्चों के अच्छे काम को पहचानें</item>
        <item>सीमाएं निर्धारित करें और अनुशासन में सुसंगत रहें</item>
        <item>अपने बच्चों के लिए समय निकालें</item>
        <item>संचार को प्राथमिकता दें</item>
        <item>लचीला रहें और अपनी पालन-पोषण शैली को समायोजित करें</item>
        <item>एक अच्छा रोल मॉडल बनें</item>
        <item>अपने प्यार को बिना शर्त दिखाएं</item>
        <item>एक माता-पिता के रूप में अपनी जरूरतों और सीमाओं को जानें</item>
        <item>अपने बच्चे को निर्णय लेना सिखाने के लिए विकल्प दें</item>
        <item>नवजात शिशुओं में खाने की आदतों में किसी भी बदलाव पर ध्यान दें</item>
